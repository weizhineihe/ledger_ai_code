<?xml version="1.0" encoding="utf-8"?>
<!--
    数据提取规则配置文件
    控制应用数据的备份和设备间传输行为
-->
<data-extraction-rules>
    <!-- 云端备份规则 -->
    <cloud-backup>
        <!-- 包含 SharedPreferences 数据 -->
        <include domain="sharedpref" path="."/>
        
        <!-- 包含数据库文件 -->
        <include domain="database" path="."/>
        
        <!-- 包含应用内部存储的文件 -->
        <include domain="file" path="."/>
        
        <!-- 排除敏感数据 -->
        <exclude domain="file" path="sensitive_data/"/>
        <exclude domain="sharedpref" path="security_prefs.xml"/>
    </cloud-backup>
    
    <!-- 设备间传输规则 -->
    <device-transfer>
        <!-- 传输 SharedPreferences 数据 -->
        <include domain="sharedpref" path="."/>
        
        <!-- 传输数据库文件 -->
        <include domain="database" path="."/>
        
        <!-- 传输应用内部存储的文件 -->
        <include domain="file" path="."/>
        
        <!-- 排除临时文件和缓存 -->
        <exclude domain="file" path="cache/"/>
        <exclude domain="file" path="temp/"/>
    </device-transfer>
</data-extraction-rules>